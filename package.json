{
	"name": "PlaylistSaber",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"deps": "npm ci",
		"clean": "rm -rf .svelte-kit",
		"build": "vite build",
		"dev": "vite dev",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "npm run lint:svelte && npm run lint:prettier && npm run lint:eslint && npm run lint:knip",
		"lint:fix": "npm run lint:svelte && npm run lint:prettier:fix && npm run lint:eslint:fix && npm run lint:knip",
		"lint:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint:prettier": "prettier --check .",
		"lint:prettier:fix": "prettier --write .",
		"lint:eslint": "eslint .",
		"lint:eslint:fix": "eslint --fix .",
		"lint:knip": "knip",
		"check": "npm run lint:svelte",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fetch-maps": "tsx scripts/fetch-maps.ts"
	},
	"devDependencies": {
		"@eslint/compat": "2.0.3",
		"@eslint/js": "9.39.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"eslint": "9.39.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-svelte": "3.15.2",
		"globals": "17.4.0",
		"knip": "^5.86.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"ky": "^2.0.2"
	}
}
